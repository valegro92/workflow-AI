# ==============================================
# Workflow AI - Environment Variables
# ==============================================
# ⚠️ ATTENZIONE: Non committare mai il file .env con credenziali reali!
# ⚠️ Questo file (.env.example) deve contenere solo placeholder.

# AI APIs - NOT REQUIRED on server
# Users provide their own free keys via the browser UI.
# These server-side keys are NO LONGER USED as fallback.
# OPENROUTER_KEY=not_needed
# GROQ_API_KEY=not_needed

# CSRF Protection (RECOMMENDED for production)
# Comma-separated list of allowed origins for CSRF protection
# Example: ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
# ALLOWED_ORIGINS=""
